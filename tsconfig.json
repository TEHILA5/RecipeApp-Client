{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - הגדרות מותאמות */
    "strict": true,
    "noUnusedLocals": false,        // ✅ כבה - לא נראה שגיאות על משתנים לא בשימוש
    "noUnusedParameters": false,    // ✅ כבה - לא נראה שגיאות על פרמטרים לא בשימוש
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    
    /* Allow any when needed */
    "noImplicitAny": false           // ✅ כבה - מאפשר any אימפליציטי
  },
  "include": ["src"], 
}